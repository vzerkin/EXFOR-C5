#ENTRY          D0876      20180212
#TITLE          Implementation of TTIK method and time of flight for
#+               resonance reaction studies at heavy ion accelerator
#+               DC-60
#AUTHORS        A.K.Nurmukhanbetova, V.Z.Goldberg, D.K.Nauruzbayev,
#+               G.V.Rogachev, M.S.Golovkov, N.A.Mynbayev, S.Artemov,
#+               A.Karakhodjaev, K.Kuterbekov, A.Rakhymzhanov,
#+               Zh.Berdibek, I.Ivanov, A.Tikhonov, V.I.Zherebchevsky,
#+               S.Yu.Torilov, R.E.Tribble
#AUTHOR1        A.K.Nurmukhanbetova+
#YEAR           2017
#X4REF1         J,NIM/A,847,125,2017
#REFERENCE1     Jour: Nucl. Instrum. Methods in Physics Res., Sect.A, Vol.847, p.125 (2017)
#DATE           20180212
#INSTITUTE      1USATAM,4ZZZDUB,4UZ UZB,4KASATN,4KASKAZ,4RUSSUL,4KASKAS,4RUSRUS
#METHOD         TTM,TOF
#REACTION_X4    (2-HE-4(7-N-15,EL)2-HE-4,,DA)=(7-N-15(A,EL)7-N-15,,DA)
#REACTION       2-HE-4(7-N-15,EL)2-HE-4,,DA
#C4Reaction     (7-N-15,EL),DA
#ReactionType   DA
#MF             4
#MT             2
#PROJ           7015
#TARG           2004             
#TARGET         2004            [ ]             2-HE-4          [ ] 
#REAC1          7-N-15,EL
